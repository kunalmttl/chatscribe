{
  "manifest_version": 3,
  "name": "ChatScribe — ChatGPT & Gemini Exporter",
  "version": "0.3.1",
  "description": "The ultimate privacy-focused AI chat exporter. Save ChatGPT or Gemini conversations to perfectly formatted Markdown or high-fidelity PDFs with zero external dependencies. Clean, dark, and developer-friendly.",
  "permissions": ["activeTab", "downloads", "scripting", "storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ChatScribe",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content/chatgpt-api.js", "content/extractor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/gemini-api.js", "content/extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/*.js", "lib/*.css"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://gemini.google.com/*"]
    }
  ]
}